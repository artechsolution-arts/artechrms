{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AR Peopliz",
  "version": "1.0.0",
  "identifier": "com.artech.hrms",
  "build": {
    "frontendDist": "../../frontend",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "AR Peopliz HRMS",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "backgroundColor": "#EEF3FC"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["English"],
        "displayLanguageSelector": false,
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE3M0UwQUIxODI3N0NGNUEKUldSYXozZUNzUW8rRjFmby84bWdENkl0bUVrclUzR3gvZEN4K3Uza1FiR2tVS05HYldaZkF0Z0wK",
      "endpoints": [
        "https://github.com/artechsolution-arts/hrms-react/releases/latest/download/latest.json"
      ]
    }
  }
}
