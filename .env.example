# Copy this file to .env and fill in real values.
# .env is git-ignored — never commit it.

# ── Database ────────────────────────────────────────────────────
# Neon DB: copy the connection string from your Neon dashboard.
# It already includes ?sslmode=require — paste it as-is.
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Security ────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_use_a_real_random_64_char_secret

# ── CORS ────────────────────────────────────────────────────────
# Set to your Railway/production domain. Never use * in production.
ALLOWED_ORIGINS=https://www.arpeopliz.com,http://localhost:3000

# ── Cloudflare R2 object storage ────────────────────────────────
# Create a bucket at dash.cloudflare.com → R2, then:
#   1. Copy your Account ID from the R2 overview page
#   2. Create an API token with "Object Read & Write" permissions
# Leave blank to use local filesystem fallback (dev only).
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=hrms

# ── Email via Microsoft 365 ──────────────────────────────────────
# Use smtp.office365.com with STARTTLS on port 587.
# IMPORTANT: SMTP AUTH must be enabled for this mailbox in Microsoft 365 admin:
#   admin.microsoft.com → Users → Active users → <user> → Mail → Manage email apps
#   → tick "Authenticated SMTP"
# If MFA is enabled on the mailbox, create an App Password instead of using your
# regular password: mysignins.microsoft.com → Security → App passwords
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=hr@yourdomain.com
SMTP_PASSWORD=your_microsoft_password_or_app_password
SMTP_FROM=AR Peopliz HRMS <hr@yourdomain.com>

# ── Microsoft SSO (Azure AD) ─────────────────────────────────────
# Set up once in Azure Portal: portal.azure.com
# See SETUP STEPS below.
# Users MUST have the same email in HRMS as in their Microsoft account.
MS_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MS_CLIENT_SECRET=your_azure_app_client_secret
MS_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MS_REDIRECT_URI=https://www.arpeopliz.com/api/auth/microsoft/callback
#
# AZURE AD SETUP STEPS:
#   1. Go to portal.azure.com → Azure Active Directory → App registrations → New registration
#   2. Name: "AR Peopliz HRMS"
#   3. Supported account types: "Accounts in this organizational directory only"
#   4. Redirect URI: Web → https://www.arpeopliz.com/api/auth/microsoft/callback
#   5. Click Register → copy the Application (client) ID  → MS_CLIENT_ID
#      Copy the Directory (tenant) ID → MS_TENANT_ID
#   6. Certificates & secrets → New client secret → copy value → MS_CLIENT_SECRET
#   7. API permissions → Add a permission → Microsoft Graph → Delegated →
#      add: openid, profile, email, User.Read → Grant admin consent

# ── Error tracking (Sentry) ──────────────────────────────────────
# Free at sentry.io. Leave blank to disable.
SENTRY_DSN=

# ── Biometric device (optional) ─────────────────────────────────
BIOMETRIC_DEVICE_IP=192.168.1.201
BIOMETRIC_DEVICE_PASSWORD=7777
BIOMETRIC_SYNC_INTERVAL_MIN=5
BIOMETRIC_SYNC_BACKFILL_DAYS=3

# ── ngrok (local HTTPS tunnel, optional) ────────────────────────
NGROK_AUTHTOKEN=
