# Copy this file to .env and fill in real values.
# .env is git-ignored — never commit it.

# ── Database ────────────────────────────────────────────────────
# URL-encode special chars in password: @ → %40
DATABASE_URL=postgresql://postgres:ARtechs%40707@host.docker.internal:5433/artechrms

# ── Security ────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_use_a_real_random_64_char_secret

# ── CORS ────────────────────────────────────────────────────────
# Comma-separated origins. Use your real domain in production, not *
ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:3000

# ── MinIO ───────────────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=hrms
MINIO_PUBLIC_URL=http://localhost:9000

# ── Biometric device (optional) ─────────────────────────────────
BIOMETRIC_DEVICE_IP=192.168.1.201
BIOMETRIC_DEVICE_PASSWORD=7777
BIOMETRIC_SYNC_INTERVAL_MIN=5
BIOMETRIC_SYNC_BACKFILL_DAYS=3

# ── ngrok (for local HTTPS tunnel, optional) ────────────────────
NGROK_AUTHTOKEN=

# ── GitHub Secrets (set in GitHub repo Settings, not here) ──────
# DEPLOY_HOST     = server IP or hostname
# DEPLOY_USER     = SSH user (ubuntu / root)
# DEPLOY_SSH_KEY  = full SSH private key PEM content
# GHCR_TOKEN      = GitHub PAT with read:packages scope
