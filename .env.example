# Copy this file to .env and fill in real values.
# .env is git-ignored — never commit it.

# ── Database ────────────────────────────────────────────────────
# Neon DB: copy the connection string from your Neon dashboard.
# It already includes ?sslmode=require — paste it as-is.
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Security ────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_use_a_real_random_64_char_secret

# ── CORS ────────────────────────────────────────────────────────
# Set to your Railway/production domain. Never use * in production.
ALLOWED_ORIGINS=https://your-app.up.railway.app,http://localhost:3000

# ── MinIO ───────────────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=hrms
MINIO_PUBLIC_URL=http://localhost:9000

# ── Email / SMTP ─────────────────────────────────────────────────
# Gmail: use an App Password (not your login password).
# Guide: myaccount.google.com/apppasswords
# Leave blank to disable email notifications silently.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=Artech HRMS <your@gmail.com>

# ── Error tracking (Sentry) ──────────────────────────────────────
# Free at sentry.io. Leave blank to disable.
SENTRY_DSN=

# ── Biometric device (optional) ─────────────────────────────────
BIOMETRIC_DEVICE_IP=192.168.1.201
BIOMETRIC_DEVICE_PASSWORD=7777
BIOMETRIC_SYNC_INTERVAL_MIN=5
BIOMETRIC_SYNC_BACKFILL_DAYS=3

# ── ngrok (local HTTPS tunnel, optional) ────────────────────────
NGROK_AUTHTOKEN=
